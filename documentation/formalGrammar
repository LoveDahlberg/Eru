Contains the grammar definition

Each grammar declaration contains a list of rules and tokens.
  - Grammar declaration are [ruleName]
  - Rules are {ruleName}
  - Tokens are (tokenName)

What precedes each grammar line must be a tabbed list of lines expanding undefined rules (with no previous grammar declaration)
declared in the previous grammar line in the order they appear.

_____

formal grammar definition:
_____

[top] -> {declaration} {top} | {directive} {top} | {function} {top} | END_OF_FILE
  
  [declaration] -> {variableDeclaration} (NEWLINE) | {functionDeclaration}
    [variableDeclaration] -> {type} (IDENTIFER) 
      [type] -> {data}
        [data] -> (INT) | (SIGNED_INT_32) | (UNSIGNED_INT_32) | (BOOl) | (STRING) | (CHAR)    
    [functionDeclaration] -> {type} (IDENTIFER) (LEFT_PARENTHESIS) {parametersDeclaration} (RIGHT_PARENTHESIS) (NEWLINE)
      [parametersDeclaration] -> {parametersDeclarationList} | e
        [parametersDeclarationList] -> {type} (IDENTIFER) | {type} (IDENTIFER) (COMMA) {parametersDeclaration}
  
  [directive] -> (LEFT_BRACKET)(RIGHT_BRACKET)

  [function] -> {type} (IDENTIFER) (LEFT_PARENTHESIS) {parametersDeclaration} (RIGHT_PARENTHESIS) {directive} (LEFT_CURLY_BRACE) {primaryExpression} (RIGHT_CURLY_BRACE)
    [primaryExpression] -> {variableDeclaration} {primaryExpression} | {assignment} {primaryExpression} | {controlflow} {primaryExpression} | {functionCall} {primaryExpression}| e
      [assignment] -> {assignmentTarget} (EQUAL) {assignmentExpression} (NEWLINE)
        [assignmentTarget] -> {variableDeclaration} | (IDENTIFER) 
        
        [assignmentExpression] -> {assignmentExpressionTarget} {operator} {assignmentExpression} | {assignmentExpressionTarget} 
          [assignmentExpressionTarget] -> (IDENTIFER) | {literal} | {functionCall} 
            [literal] -> (STRING_LITERAL) | (INTEGER_LITERAL)          
            [functionCall] -> (IDENTIFER) (LEFT_PARENTHESIS) {parametersCall} (RIGHT_PARENTHESIS)
              [parametersCall] -> {prametersCallList} | e
                [prametersCallList] -> {assignmentExpressionTarget} | {assignmentExpressionTarget} (COMMA) {prametersCallList}
          [operator] -> (PLUS) | (MINUS) 

      [controlflow] -> {conditionalBranch}
        [conditionalBranch] -> (IF) {conditinalExpression} {continuedCondition}
          [conditinalExpression] -> (LEFT_PARENTHESIS) {booleanExpression} (RIGHT_PARENTHESIS) (LEFT_CURLY_BRACE) {primaryExpression} (RIGHT_CURLY_BRACE)
            [booleanExpression] -> {assignmentExpression} {booleanExpressionList}
              [booleanExpressionList] -> {booleanOperator} {booleanExpression} | e
                [booleanOperator] -> (AND) | (OR)
          [continuedCondition] -> (ELSE) {conditinalExpression} | (ELIF) {conditinalExpression} {continuedCondition} | e

_____

Token definition:
_____

(IDENTIFER) -> [a-zA-Z_][a-zA-Z0-9_]*

(IF) -> if
(ELSE) -> else
(ELIF) -> elif
(AND) -> and
(OR) -> or

(LEFT_PARENTHESIS) -> (
(RIGHT_PARENTHESIS) -> )
(LEFT_CURLY_BRACE) -> {
(RIGHT_CURLY_BRACE) -> }
(LEFT_BRACKET) -> [
(RIGHT_BRACKET) -> ]
(COMMA) -> ,
(NEWLINE) -> \n | \r | \n\r

(INT) -> int
(SIGNED_INT_32) -> sint32
(UNSIGNED_INT_32) -> uint32
(BOOL) -> true | false
(STRING) -> string
(CHAR) -> char

(PLUS) -> +
(MINUS) -> -
(EQUAL) -> =

(INTEGER_LITERAL) -> [0-9]+
(STRING_LITERAL) -> ".*"

(END_OF_FILE) -> EOF